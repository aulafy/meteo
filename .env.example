# Copia este archivo a .env.local solo para desarrollo.
# No escribas valores reales en Git, documentación, pruebas o capturas.

# --- NAVEGADOR: las variables VITE_* son públicas ---
# Feed estático sin secretos. Si se omite, la app usa su valor por defecto.
VITE_FIRES_URL=https://aulafy.github.io/meteo/fires.json

# --- SERVIDOR: Supabase y alertas Web Push opcionales ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@example.com
CRON_SECRET=
FIRMS_FEED_URL=https://aulafy.github.io/meteo/fires.json

# --- SERVIDOR: explicación IA opcional ---
# La interfaz principal funciona sin configurar estas variables.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
